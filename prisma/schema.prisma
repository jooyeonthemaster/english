// ============================================================================
// NARA - 영어학원 AI ERP Platform
// Provider: PostgreSQL (Supabase)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// 1. CORE — Academy, Staff, School, Student, Parent
// ============================================================================

/// Academy (학원) — the root tenant entity
/// status: "ACTIVE" | "TRIAL" | "SUSPENDED" | "DEACTIVATED"
model Academy {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  address   String?
  logoUrl   String?
  color     String?  @default("#3B82F6") // Brand color
  status    String   @default("ACTIVE") // "ACTIVE" | "TRIAL" | "SUSPENDED" | "DEACTIVATED"
  settings  String?  @db.Text // JSON: business hours, notification prefs, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  staff               Staff[]
  students            Student[]
  parents             Parent[]
  schools             School[]
  classes             Class[]
  attendances         Attendance[]
  invoices            Invoice[]
  expenses            Expense[]
  salaries            Salary[]
  notices             Notice[]
  calendarEvents      CalendarEvent[]
  consultations       Consultation[]
  assignments         Assignment[]
  passages            Passage[]
  questions           Question[]
  questionCollections QuestionCollection[]
  passageCollections  PassageCollection[]
  examCollections     ExamCollection[]
  exams               Exam[]
  vocabLists          VocabularyList[]
  teacherPrompts      TeacherPrompt[]
  textbooks           Textbook[]
  achievements        Achievement[]
  studySeasons        StudySeason[]
  naeshinQuestions    NaeshinQuestion[]
  learningSets        LearningSet[]
  subscriptions       AcademySubscription[]
  creditBalance       CreditBalance?
  creditTransactions  CreditTransaction[]
  creditTopUps        CreditTopUp[]
  extractionJobs      ExtractionJob[]
  sourceMaterials     SourceMaterial[]

  @@map("academies")
}

/// Staff — Directors and Teachers
/// role: "DIRECTOR" | "TEACHER"
model Staff {
  id        String   @id @default(cuid())
  academyId String
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("TEACHER") // "DIRECTOR" | "TEACHER"
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  academy                Academy           @relation(fields: [academyId], references: [id])
  classes                Class[] // Classes taught
  staffAttendances       StaffAttendance[]
  salaries               Salary[]
  consultations          Consultation[]
  messages               Message[]         @relation("SentMessages")
  receivedMessages       Message[]         @relation("ReceivedStaffMessages")
  extractionJobs         ExtractionJob[]   @relation("ExtractionJobCreator")
  createdSourceMaterials SourceMaterial[]  @relation("SourceMaterialCreator")

  @@index([academyId])
  @@map("staff")
}

/// School — Reference schools that students attend (강동중, 명일여고 etc.)
/// type: "MIDDLE" | "HIGH" | "ELEMENTARY"
model School {
  id        String   @id @default(cuid())
  academyId String
  name      String
  slug      String
  type      String // "MIDDLE" | "HIGH" | "ELEMENTARY"
  publisher String? // 교과서 출판사
  createdAt DateTime @default(now())

  // Relations
  academy          Academy           @relation(fields: [academyId], references: [id])
  students         Student[]
  passages         Passage[]
  exams            Exam[]
  naeshinQuestions NaeshinQuestion[]
  sourceMaterials  SourceMaterial[]

  @@unique([academyId, slug])
  @@index([academyId])
  @@map("schools")
}

/// Student — Academy students
/// status: "ACTIVE" | "PAUSED" | "WITHDRAWN" | "WAITING"
/// gender: "MALE" | "FEMALE" | null
model Student {
  id           String    @id @default(cuid())
  academyId    String
  name         String
  studentCode  String    @unique // 4-digit login code
  birthDate    DateTime?
  gender       String? // "MALE" | "FEMALE"
  phone        String?
  schoolId     String?
  grade        Int
  status       String    @default("ACTIVE") // "ACTIVE" | "PAUSED" | "WITHDRAWN" | "WAITING"
  enrollDate   DateTime  @default(now())
  withdrawDate DateTime?
  pauseDate    DateTime?
  memo         String?   @db.Text // Special notes (allergies, personality, etc.)
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Gamification
  xp                Int       @default(0)
  level             Int       @default(1)
  streak            Int       @default(0)
  streakFreezeCount Int       @default(0) // max 3
  lastStudyDate     DateTime?

  // Relations
  academy                Academy                 @relation(fields: [academyId], references: [id])
  school                 School?                 @relation(fields: [schoolId], references: [id])
  parentLinks            ParentStudent[]
  classEnrollments       ClassEnrollment[]
  attendances            Attendance[]
  invoices               Invoice[]
  consultations          Consultation[]
  assignmentSubs         AssignmentSubmission[]
  examSubmissions        ExamSubmission[]
  vocabTestResults       VocabTestResult[]
  wrongVocabAnswers      WrongVocabAnswer[]
  aiConversations        AIConversation[]
  studyProgress          StudyProgress[]
  studentAchievements    StudentAchievement[]
  studentAnalytics       StudentAnalytics?
  parentReports          ParentReport[]
  wrongAnswerLogs        WrongAnswerLog[]
  lessonProgress         LessonProgress[]
  sessionRecords         SessionRecord[]
  dailyMissions          StudentDailyMission[]
  naeshinWrongAnswerLogs NaeshinWrongAnswerLog[]
  suneungWrongAnswerLogs SuneungWrongAnswerLog[]

  @@index([academyId])
  @@index([schoolId])
  @@index([academyId, status])
  @@map("students")
}

/// Parent — Student guardians
model Parent {
  id               String   @id @default(cuid())
  academyId        String
  name             String
  phone            String
  email            String?
  relation         String? // "MOTHER" | "FATHER" | "GUARDIAN" | "OTHER"
  emergencyContact String?
  memo             String?  @db.Text
  loginToken       String?  @unique // For passwordless parent login via link
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  academy       Academy         @relation(fields: [academyId], references: [id])
  studentLinks  ParentStudent[]
  parentReports ParentReport[]
  messages      Message[]       @relation("ParentMessages")

  @@index([academyId])
  @@index([phone])
  @@map("parents")
}

/// ParentStudent — Many-to-many: Parent ↔ Student (siblings support)
model ParentStudent {
  id        String @id @default(cuid())
  parentId  String
  studentId String

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

// ============================================================================
// 2. CLASS MANAGEMENT
// ============================================================================

/// Class — Academy classes (반)
model Class {
  id        String   @id @default(cuid())
  academyId String
  name      String
  teacherId String?
  schedule  String?  @db.Text // JSON: [{ day: "MON", startTime: "14:00", endTime: "16:00" }]
  capacity  Int      @default(20)
  fee       Int      @default(0) // Monthly fee in KRW
  room      String? // Classroom name/number
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  academy     Academy           @relation(fields: [academyId], references: [id])
  teacher     Staff?            @relation(fields: [teacherId], references: [id])
  enrollments ClassEnrollment[]
  attendances Attendance[]
  assignments Assignment[]
  exams       Exam[]

  @@index([academyId])
  @@index([teacherId])
  @@map("classes")
}

/// ClassEnrollment — Student ↔ Class enrollment (supports multiple classes)
/// status: "ENROLLED" | "WAITLISTED" | "DROPPED"
model ClassEnrollment {
  id         String    @id @default(cuid())
  classId    String
  studentId  String
  status     String    @default("ENROLLED") // "ENROLLED" | "WAITLISTED" | "DROPPED"
  enrolledAt DateTime  @default(now())
  droppedAt  DateTime?

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([studentId])
  @@map("class_enrollments")
}

// ============================================================================
// 3. ATTENDANCE
// ============================================================================

/// Attendance — Student attendance records
/// status: "PRESENT" | "ABSENT" | "LATE" | "EARLY_LEAVE" | "MAKEUP"
model Attendance {
  id           String    @id @default(cuid())
  academyId    String
  studentId    String
  classId      String?
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       String    @default("PRESENT") // "PRESENT" | "ABSENT" | "LATE" | "EARLY_LEAVE" | "MAKEUP"
  note         String?
  method       String? // "KIOSK" | "QR" | "MANUAL"
  createdAt    DateTime  @default(now())

  // Relations
  academy Academy @relation(fields: [academyId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([academyId, date])
  @@index([studentId, date])
  @@map("attendances")
}

/// StaffAttendance — Staff clock-in/out records
model StaffAttendance {
  id       String    @id @default(cuid())
  staffId  String
  date     DateTime
  checkIn  DateTime?
  checkOut DateTime?
  note     String?

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([staffId, date])
  @@map("staff_attendances")
}

// ============================================================================
// 4. BILLING & FINANCE
// ============================================================================

/// Invoice — Monthly billing records
/// status: "PENDING" | "PAID" | "OVERDUE" | "PARTIAL" | "REFUNDED" | "CANCELLED"
model Invoice {
  id          String    @id @default(cuid())
  academyId   String
  studentId   String
  title       String // e.g. "2026년 3월 수강료"
  amount      Int // Total amount in KRW
  discount    Int       @default(0) // Discount amount
  finalAmount Int // amount - discount
  dueDate     DateTime
  paidDate    DateTime?
  status      String    @default("PENDING")
  memo        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  academy  Academy   @relation(fields: [academyId], references: [id])
  student  Student   @relation(fields: [studentId], references: [id])
  payments Payment[]

  @@index([academyId, status])
  @@index([studentId])
  @@index([academyId, dueDate])
  @@map("invoices")
}

/// Payment — Individual payment transactions
/// method: "CARD" | "TRANSFER" | "CASH" | "KAKAO_PAY" | "NAVER_PAY" | "TOSS"
model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Int
  method    String // "CARD" | "TRANSFER" | "CASH" | "KAKAO_PAY" | "NAVER_PAY" | "TOSS"
  reference String? // Transaction ID from payment gateway
  paidAt    DateTime @default(now())
  memo      String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

/// Expense — Academy expenditures
/// category: "RENT" | "SALARY" | "MATERIALS" | "MARKETING" | "UTILITIES" | "MAINTENANCE" | "OTHER"
model Expense {
  id          String   @id @default(cuid())
  academyId   String
  category    String // "RENT" | "SALARY" | "MATERIALS" | "MARKETING" | "UTILITIES" | "MAINTENANCE" | "OTHER"
  amount      Int
  date        DateTime
  description String?
  receipt     String? // Receipt image URL
  createdAt   DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id])

  @@index([academyId, date])
  @@index([academyId, category])
  @@map("expenses")
}

/// Salary — Staff salary records
model Salary {
  id         String    @id @default(cuid())
  academyId  String
  staffId    String
  month      String // "2026-03" format
  basePay    Int
  bonus      Int       @default(0)
  deductions Int       @default(0)
  totalPay   Int
  paidAt     DateTime?
  memo       String?
  createdAt  DateTime  @default(now())

  academy Academy @relation(fields: [academyId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])

  @@unique([staffId, month])
  @@index([academyId, month])
  @@map("salaries")
}

// ============================================================================
// 5. COMMUNICATION
// ============================================================================

/// Notice — Announcements
/// targetType: "ALL" | "CLASS" | "INDIVIDUAL" | "PARENTS"
model Notice {
  id         String   @id @default(cuid())
  academyId  String
  title      String
  content    String   @db.Text
  targetType String   @default("ALL") // "ALL" | "CLASS" | "INDIVIDUAL" | "PARENTS"
  targetId   String? // classId or studentId depending on targetType
  isPinned   Boolean  @default(false)
  publishAt  DateTime @default(now()) // Scheduled publish time
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  academy Academy      @relation(fields: [academyId], references: [id])
  reads   NoticeRead[]

  @@index([academyId, publishAt])
  @@map("notices")
}

/// NoticeRead — Track who read the notice
model NoticeRead {
  id         String   @id @default(cuid())
  noticeId   String
  readerId   String // parentId or studentId
  readerType String // "PARENT" | "STUDENT"
  readAt     DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@unique([noticeId, readerId, readerType])
  @@map("notice_reads")
}

/// Message — 1:1 messages (Teacher ↔ Parent, Director ↔ Anyone)
model Message {
  id           String   @id @default(cuid())
  senderId     String
  senderType   String // "STAFF" | "PARENT"
  receiverId   String
  receiverType String // "STAFF" | "PARENT"
  content      String   @db.Text
  attachments  String?  @db.Text // JSON array of file URLs
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Polymorphic relations
  senderStaff   Staff?  @relation("SentMessages", fields: [senderId], references: [id], map: "msg_sender_staff")
  receiverStaff Staff?  @relation("ReceivedStaffMessages", fields: [receiverId], references: [id], map: "msg_receiver_staff")
  senderParent  Parent? @relation("ParentMessages", fields: [senderId], references: [id], map: "msg_sender_parent")

  @@index([receiverId, receiverType, isRead])
  @@index([senderId, senderType])
  @@map("messages")
}

/// CalendarEvent — Academy calendar
/// type: "EXAM" | "EVENT" | "HOLIDAY" | "MEETING" | "OTHER"
model CalendarEvent {
  id          String    @id @default(cuid())
  academyId   String
  title       String
  description String?   @db.Text
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  type        String    @default("EVENT") // "EXAM" | "EVENT" | "HOLIDAY" | "MEETING" | "OTHER"
  color       String? // Custom event color
  createdAt   DateTime  @default(now())

  academy Academy @relation(fields: [academyId], references: [id])

  @@index([academyId, startDate])
  @@map("calendar_events")
}

// ============================================================================
// 6. CONSULTATION
// ============================================================================

/// Consultation — Counseling records
/// type: "NEW_INQUIRY" | "STUDENT" | "PARENT" | "LEVEL_TEST"
/// channel: "PHONE" | "VISIT" | "ONLINE" | "KAKAO"
/// status: "SCHEDULED" | "COMPLETED" | "CANCELLED" | "FOLLOW_UP"
model Consultation {
  id           String    @id @default(cuid())
  academyId    String
  studentId    String?
  staffId      String? // Counselor
  type         String // "NEW_INQUIRY" | "STUDENT" | "PARENT" | "LEVEL_TEST"
  channel      String? // "PHONE" | "VISIT" | "ONLINE" | "KAKAO"
  status       String    @default("SCHEDULED") // "SCHEDULED" | "COMPLETED" | "CANCELLED" | "FOLLOW_UP"
  date         DateTime
  content      String?   @db.Text
  category     String? // "GRADE" | "ATTITUDE" | "CAREER" | "PARENT_REQUEST" | "OTHER"
  followUpDate DateTime?
  followUpNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  academy Academy  @relation(fields: [academyId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])
  staff   Staff?   @relation(fields: [staffId], references: [id])

  @@index([academyId, date])
  @@index([studentId])
  @@map("consultations")
}

// ============================================================================
// 7. ASSIGNMENT
// ============================================================================

/// Assignment — Homework and tasks
/// targetType: "CLASS" | "INDIVIDUAL"
model Assignment {
  id          String   @id @default(cuid())
  academyId   String
  classId     String?
  title       String
  description String?  @db.Text
  targetType  String   @default("CLASS") // "CLASS" | "INDIVIDUAL"
  dueDate     DateTime
  maxScore    Int? // If graded
  attachments String?  @db.Text // JSON array of file URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy     Academy                @relation(fields: [academyId], references: [id])
  class       Class?                 @relation(fields: [classId], references: [id])
  submissions AssignmentSubmission[]

  @@index([academyId, dueDate])
  @@index([classId])
  @@map("assignments")
}

/// AssignmentSubmission — Student submissions
/// status: "PENDING" | "SUBMITTED" | "LATE" | "GRADED"
model AssignmentSubmission {
  id           String    @id @default(cuid())
  assignmentId String
  studentId    String
  status       String    @default("PENDING") // "PENDING" | "SUBMITTED" | "LATE" | "GRADED"
  content      String?   @db.Text
  attachments  String?   @db.Text // JSON
  score        Int?
  feedback     String?   @db.Text
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

// ============================================================================
// 8. AI CONTENT — Passages
// ============================================================================

/// Passage — Text passages for study and question generation
/// difficulty: "BEGINNER" | "ELEMENTARY" | "INTERMEDIATE" | "UPPER_INTERMEDIATE" | "ADVANCED" | "EXPERT"
model Passage {
  id         String  @id @default(cuid())
  academyId  String
  schoolId   String? // Optional: school-specific passage
  title      String
  content    String  @db.Text
  source     String? // Source reference (legacy free-form)
  grade      Int?
  semester   String? // "FIRST" | "SECOND"
  unit       String?
  publisher  String? // 교과서 출판사
  difficulty String? // "BEGINNER" ~ "EXPERT"
  tags       String? @db.Text // JSON array of tags
  order      Int     @default(0)

  // ── Extraction lineage (nullable — manual passages stay untouched) ──
  sourceMaterialId       String?
  sourceExtractionItemId String? @unique
  contentHash            String? // sha1 of content — duplicate detection

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  academy          Academy                 @relation(fields: [academyId], references: [id])
  school           School?                 @relation(fields: [schoolId], references: [id])
  sourceMaterial   SourceMaterial?         @relation(fields: [sourceMaterialId], references: [id])
  notes            PassageNote[]
  analysis         PassageAnalysis?
  questions        Question[]
  teacherPrompts   TeacherPrompt[]
  seasonLinks      SeasonPassage[]
  lessonProgress   LessonProgress[]
  sessionRecords   SessionRecord[]
  naeshinQuestions NaeshinQuestion[]
  learningSets     LearningSet[]
  collectionItems  PassageCollectionItem[]
  bundles          PassageBundle[]

  @@index([academyId])
  @@index([schoolId])
  @@index([academyId, grade, semester])
  @@index([sourceMaterialId])
  @@index([contentHash])
  @@map("passages")
}

/// PassageAnalysis — AI-generated analysis cache
model PassageAnalysis {
  id           String   @id @default(cuid())
  passageId    String   @unique
  analysisData String   @db.Text // JSON: sentences, vocab, grammar, structure
  contentHash  String // MD5 for change detection
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passage Passage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@map("passage_analyses")
}

/// PassageNote — Teacher annotations on passages (Tiptap marks + memos).
/// noteType: "vocab" | "grammar" | "syntax" | "sentence" | "examPoint"
///   (5 marking types matching PassageAnnotationEditor; legacy values EMPHASIS/TIP still accepted)
/// content: the selected passage text (what the teacher highlighted)
/// memo: the teacher's note about WHY they marked it (fed to AI as intent signal)
/// annotationId: client-side UUID used by the Tiptap mark to round-trip selections
/// highlightStart / highlightEnd: ProseMirror positions (from/to) for mark restoration
model PassageNote {
  id             String   @id @default(cuid())
  passageId      String
  annotationId   String? // matches Tiptap mark attrs.id for client round-trip
  content        String   @db.Text
  memo           String   @default("") @db.Text
  highlightStart Int?
  highlightEnd   Int?
  noteType       String   @default("vocab")
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  passage Passage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@index([passageId])
  @@index([passageId, annotationId])
  @@map("passage_notes")
}

// ============================================================================
// 9. AI CONTENT — Questions & Question Bank
// ============================================================================

/// Question — Question bank (AI-generated or manual)
/// type: "MULTIPLE_CHOICE" | "SHORT_ANSWER" | "ESSAY" | "FILL_BLANK" | "ORDERING" | "VOCAB"
/// subType: Specific question pattern (e.g. "BLANK_INFERENCE", "GRAMMAR_ERROR", "SENTENCE_INSERT" etc.)
/// difficulty: "BASIC" | "INTERMEDIATE" | "KILLER"
model Question {
  id               String  @id @default(cuid())
  academyId        String
  passageId        String? // Source passage (if passage-based)
  type             String // "MULTIPLE_CHOICE" | "SHORT_ANSWER" | "ESSAY" | "FILL_BLANK" | "ORDERING" | "VOCAB"
  subType          String? // Specific pattern within type
  questionText     String  @db.Text
  questionImage    String? // Image URL
  options          String? @db.Text // JSON: [{ label: "①", text: "..." }, ...] for MC
  correctAnswer    String  @db.Text // Answer text or JSON for complex answers
  points           Int     @default(1)
  difficulty       String  @default("INTERMEDIATE") // "BASIC" | "INTERMEDIATE" | "KILLER"
  tags             String? @db.Text // JSON: ["관계대명사", "시제", ...] for filtering
  learningCategory String? // "VOCAB" | "INTERPRETATION" | "GRAMMAR" | "COMPREHENSION"
  aiGenerated      Boolean @default(false)
  approved         Boolean @default(false) // Teacher review status
  starred          Boolean @default(false) // Important/starred by teacher

  // ── Extraction lineage (nullable — manual questions stay untouched) ──
  sourceMaterialId       String?
  bundleId               String?
  sourceExtractionItemId String? @unique
  questionNumber         Int? // printed number on the original exam (e.g. 33)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  academy         Academy                  @relation(fields: [academyId], references: [id])
  passage         Passage?                 @relation(fields: [passageId], references: [id])
  sourceMaterial  SourceMaterial?          @relation(fields: [sourceMaterialId], references: [id])
  bundle          PassageBundle?           @relation("BundleQuestions", fields: [bundleId], references: [id])
  explanation     QuestionExplanation?
  examLinks       ExamQuestion[]
  wrongLogs       WrongAnswerLog[]
  aiConversations AIConversation[]
  collectionItems QuestionCollectionItem[]

  @@index([academyId])
  @@index([passageId])
  @@index([academyId, type, difficulty])
  @@index([academyId, approved])
  @@index([sourceMaterialId])
  @@index([bundleId])
  @@map("questions")
}

/// QuestionExplanation — Detailed explanation for each question
model QuestionExplanation {
  id                      String   @id @default(cuid())
  questionId              String   @unique
  content                 String   @db.Text // Rich HTML explanation
  keyPoints               String?  @db.Text // JSON string array
  wrongOptionExplanations String?  @db.Text // JSON: { "1": "왜 틀렸는지...", "2": "..." }
  relatedGrammar          String?  @db.Text // Related grammar rules
  difficulty              String?
  aiGenerated             Boolean  @default(false)
  approved                Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_explanations")
}

// ============================================================================
// 10. EXAMS
// ============================================================================

/// Exam — Test papers (online CBT or offline)
/// type: "OFFLINE" | "ONLINE" | "VOCAB" | "MOCK"
/// status: "DRAFT" | "PUBLISHED" | "IN_PROGRESS" | "COMPLETED" | "ARCHIVED"
model Exam {
  id               String    @id @default(cuid())
  academyId        String
  schoolId         String? // Optional school association
  classId          String? // Optional class association
  title            String
  type             String // "OFFLINE" | "ONLINE" | "VOCAB" | "MOCK"
  status           String    @default("DRAFT") // "DRAFT" | "PUBLISHED" | "IN_PROGRESS" | "COMPLETED" | "ARCHIVED"
  grade            Int?
  semester         String? // "FIRST" | "SECOND"
  examType         String? // "MIDTERM" | "FINAL" | "QUIZ" | "MOCK"
  year             Int?
  examDate         DateTime?
  duration         Int? // Time limit in minutes (for online)
  totalPoints      Int       @default(100)
  shuffleQuestions Boolean   @default(false) // Anti-cheat for online
  shuffleOptions   Boolean   @default(false)
  showResults      Boolean   @default(true) // Show results immediately after submission
  settings         String?   @db.Text // JSON: additional exam settings

  // ── Extraction lineage ──
  sourceMaterialId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  academy         Academy              @relation(fields: [academyId], references: [id])
  school          School?              @relation(fields: [schoolId], references: [id])
  class           Class?               @relation(fields: [classId], references: [id])
  sourceMaterial  SourceMaterial?      @relation(fields: [sourceMaterialId], references: [id])
  questions       ExamQuestion[]
  submissions     ExamSubmission[]
  collectionItems ExamCollectionItem[]

  @@index([academyId])
  @@index([academyId, status])
  @@index([schoolId])
  @@index([sourceMaterialId])
  @@map("exams")
}

/// ExamQuestion — Links questions to exams with ordering and point values
model ExamQuestion {
  id         String @id @default(cuid())
  examId     String
  questionId String
  orderNum   Int
  points     Int    @default(1)

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, orderNum])
  @@unique([examId, questionId])
  @@index([examId])
  @@map("exam_questions")
}

/// ExamSubmission — Student exam submissions
/// status: "IN_PROGRESS" | "SUBMITTED" | "GRADED"
model ExamSubmission {
  id          String    @id @default(cuid())
  examId      String
  studentId   String
  answers     String    @db.Text // JSON: { "questionId": "answer", ... }
  score       Int? // Total score (null until graded)
  maxScore    Int?
  percent     Float?
  status      String    @default("IN_PROGRESS") // "IN_PROGRESS" | "SUBMITTED" | "GRADED"
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  gradedAt    DateTime?
  gradedBy    String? // staffId who graded (for manual grading)

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("exam_submissions")
}

// ============================================================================
// 11. VOCABULARY
// ============================================================================

/// VocabularyList — Word lists for study and testing
model VocabularyList {
  id        String   @id @default(cuid())
  academyId String
  title     String
  grade     Int?
  semester  String? // "FIRST" | "SECOND"
  unit      String?
  schoolId  String? // Optional school-specific
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy     Academy           @relation(fields: [academyId], references: [id])
  items       VocabularyItem[]
  testResults VocabTestResult[]

  @@index([academyId])
  @@map("vocabulary_lists")
}

/// VocabularyItem — Individual vocabulary words
model VocabularyItem {
  id           String   @id @default(cuid())
  listId       String
  english      String
  korean       String
  partOfSpeech String?
  exampleEn    String?
  exampleKr    String?
  phonetic     String?
  synonyms     String? // Comma-separated
  antonyms     String? // Comma-separated
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  list         VocabularyList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  wrongAnswers WrongVocabAnswer[]

  @@index([listId])
  @@map("vocabulary_items")
}

/// VocabTestResult — Vocabulary test results
/// testType: "EN_TO_KR" | "KR_TO_EN" | "SPELLING"
model VocabTestResult {
  id        String   @id @default(cuid())
  studentId String
  listId    String
  testType  String // "EN_TO_KR" | "KR_TO_EN" | "SPELLING"
  score     Int
  total     Int
  percent   Float
  duration  Int? // seconds
  takenAt   DateTime @default(now())

  student Student        @relation(fields: [studentId], references: [id])
  list    VocabularyList @relation(fields: [listId], references: [id])

  @@index([studentId, takenAt])
  @@index([listId, takenAt])
  @@map("vocab_test_results")
}

/// WrongVocabAnswer — Tracks vocabulary mistakes
model WrongVocabAnswer {
  id           String   @id @default(cuid())
  studentId    String
  itemId       String
  testType     String // "EN_TO_KR" | "KR_TO_EN" | "SPELLING"
  givenAnswer  String
  count        Int      @default(1)
  lastMissedAt DateTime @default(now())

  student Student        @relation(fields: [studentId], references: [id])
  item    VocabularyItem @relation(fields: [itemId], references: [id])

  @@unique([studentId, itemId, testType])
  @@index([studentId])
  @@map("wrong_vocab_answers")
}

// ============================================================================
// 12. ANALYTICS & GAMIFICATION
// ============================================================================

/// StudentAnalytics — Comprehensive student performance data ("영어 인바디")
model StudentAnalytics {
  id             String   @id @default(cuid())
  studentId      String   @unique
  overallScore   Float    @default(0) // 0-100 composite score
  grammarScore   Float    @default(0) // 0-100
  vocabScore     Float    @default(0) // 0-100
  readingScore   Float    @default(0) // 0-100
  writingScore   Float    @default(0) // 0-100
  listeningScore Float    @default(0) // 0-100
  level          String   @default("D") // "S" | "A" | "B" | "C" | "D"
  // Detailed grammar breakdown (JSON)
  grammarDetail  String?  @db.Text // JSON: { "tense": 85, "passive": 60, "relative": 40, ... }
  // Detailed weak points
  weakPoints     String?  @db.Text // JSON: ["관계대명사 who/which 구분", ...]
  updatedAt      DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@map("student_analytics")
}

/// WrongAnswerLog — Tracks wrong answers for pattern analysis
model WrongAnswerLog {
  id          String   @id @default(cuid())
  studentId   String
  questionId  String
  givenAnswer String
  category    String? // "GRAMMAR" | "VOCAB" | "READING" | "WRITING"
  subCategory String? // "TENSE" | "RELATIVE_PRONOUN" | "SYNONYM" etc.
  count       Int      @default(1)
  lastWrongAt DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([studentId, questionId])
  @@index([studentId, category])
  @@map("wrong_answer_logs")
}

/// StudyProgress — Daily study tracking
model StudyProgress {
  id                String   @id @default(cuid())
  studentId         String
  date              DateTime
  vocabTests        Int      @default(0)
  vocabScore        Float    @default(0)
  questionsViewed   Int      @default(0)
  questionsAnswered Int      @default(0)
  aiQuestionsAsked  Int      @default(0)
  studyMinutes      Int      @default(0)
  xpEarned          Int      @default(0)

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@index([studentId])
  @@map("study_progress")
}

/// Achievement — Available badges/achievements
/// category: "ATTENDANCE" | "VOCAB" | "GRAMMAR" | "GROWTH" | "ASSIGNMENT" | "STREAK"
model Achievement {
  id          String @id @default(cuid())
  academyId   String
  name        String
  description String
  icon        String // Emoji or icon identifier
  category    String // "ATTENDANCE" | "VOCAB" | "GRAMMAR" | "GROWTH" | "ASSIGNMENT" | "STREAK"
  condition   String @db.Text // JSON: { type: "STREAK", value: 7 } or { type: "SCORE", min: 90, count: 3 }
  xpReward    Int    @default(0)

  academy             Academy              @relation(fields: [academyId], references: [id])
  studentAchievements StudentAchievement[]

  @@index([academyId])
  @@map("achievements")
}

/// StudentAchievement — Earned badges
model StudentAchievement {
  id            String   @id @default(cuid())
  studentId     String
  achievementId String
  earnedAt      DateTime @default(now())

  student     Student     @relation(fields: [studentId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([studentId, achievementId])
  @@map("student_achievements")
}

// ============================================================================
// 13. AI CONVERSATIONS & PROMPTS
// ============================================================================

/// AIConversation — Student ↔ AI chat history per question
model AIConversation {
  id         String   @id @default(cuid())
  studentId  String
  questionId String
  messages   String   @db.Text // JSON: [{ role, content, timestamp }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student  Student  @relation(fields: [studentId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([studentId, questionId])
  @@index([studentId])
  @@index([questionId])
  @@map("ai_conversations")
}

/// TeacherPrompt — Custom AI instructions per school/passage
/// promptType: "GENERAL" | "GRAMMAR" | "VOCAB" | "EXAM_FOCUS" | "QUESTION_GENERATION"
model TeacherPrompt {
  id         String   @id @default(cuid())
  academyId  String
  staffId    String?
  passageId  String?
  name       String   @default("")
  content    String   @db.Text
  promptType String   @default("GENERAL")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  academy Academy  @relation(fields: [academyId], references: [id])
  passage Passage? @relation(fields: [passageId], references: [id])

  @@index([academyId])
  @@index([academyId, promptType])
  @@index([academyId, passageId])
  @@map("teacher_prompts")
}

// ============================================================================
// 14. PARENT REPORTS
// ============================================================================

/// ParentReport — Auto-generated reports sent to parents
/// type: "WEEKLY" | "MONTHLY" | "CUSTOM"
/// status: "DRAFT" | "SENT" | "VIEWED"
model ParentReport {
  id         String    @id @default(cuid())
  studentId  String
  parentId   String?
  type       String // "WEEKLY" | "MONTHLY" | "CUSTOM"
  reportData String    @db.Text // JSON: scores, attendance, analysis, teacher comment
  status     String    @default("DRAFT") // "DRAFT" | "SENT" | "VIEWED"
  sentAt     DateTime?
  viewedAt   DateTime?
  createdAt  DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id])
  parent  Parent? @relation(fields: [parentId], references: [id])

  @@index([studentId])
  @@index([parentId])
  @@map("parent_reports")
}

// ============================================================================
// 15. TEXTBOOK / CURRICULUM
// ============================================================================

/// Textbook — Publisher textbook references
model Textbook {
  id        String  @id @default(cuid())
  academyId String
  publisher String // "능률" | "비상" | "YBM" | "천재" | "지학사"
  title     String
  grade     Int?
  year      Int?
  chapters  String? @db.Text // JSON: [{ unit: 1, title: "..." }]

  academy Academy @relation(fields: [academyId], references: [id])

  @@index([academyId])
  @@map("textbooks")
}

// ============================================================================
// QUESTION COLLECTIONS (YouTube-playlist-style grouping)
// ============================================================================

model QuestionCollection {
  id          String   @id @default(cuid())
  academyId   String
  parentId    String? // Self-reference for nested folders (null = root)
  name        String
  description String?  @db.Text
  color       String? // Hex color for visual distinction
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy  Academy                  @relation(fields: [academyId], references: [id])
  parent   QuestionCollection?      @relation("QuestionFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children QuestionCollection[]     @relation("QuestionFolderTree")
  items    QuestionCollectionItem[]

  @@index([academyId])
  @@index([parentId])
  @@map("question_collections")
}

model QuestionCollectionItem {
  id           String @id @default(cuid())
  collectionId String
  questionId   String
  orderNum     Int    @default(0)

  collection QuestionCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  question   Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, questionId])
  @@index([collectionId])
  @@map("question_collection_items")
}

// ============================================================================
// 16. DUOLINGO-STYLE LEARNING SERVICE
// ============================================================================

/// StudySeason — 학습 시즌 (내신 집중 기간 or 평상시)
/// type: "EXAM_PREP" | "REGULAR"
model StudySeason {
  id          String   @id @default(cuid())
  academyId   String
  name        String // "1학기 중간고사 대비" etc.
  type        String // "EXAM_PREP" | "REGULAR"
  grade       Int? // 대상 학년
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdById String? // staffId (강사)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy        Academy          @relation(fields: [academyId], references: [id])
  passages       SeasonPassage[]
  sessionRecords SessionRecord[]
  lessonProgress LessonProgress[]

  @@index([academyId])
  @@index([academyId, isActive])
  @@map("study_seasons")
}

/// SeasonPassage — 시즌에 배정된 지문 (순서 포함)
model SeasonPassage {
  id        String @id @default(cuid())
  seasonId  String
  passageId String
  order     Int    @default(0)

  season  StudySeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  passage Passage     @relation(fields: [passageId], references: [id])

  @@unique([seasonId, passageId])
  @@index([seasonId])
  @@map("season_passages")
}

/// LessonProgress — 학생의 레슨(지문)별 진행도
model LessonProgress {
  id        String  @id @default(cuid())
  studentId String
  passageId String
  seasonId  String?

  session1Done Boolean @default(false) // 필수: 종합 믹스 1
  session2Done Boolean @default(false) // 필수: 종합 믹스 2
  storiesDone  Boolean @default(false) // 필수: Stories 통독
  session3Done Boolean @default(false) // 선택: 어휘 집중
  session4Done Boolean @default(false) // 선택: 문법 집중
  session5Done Boolean @default(false) // 선택: 약점 집중

  masteryScore Float    @default(0) // 숙달도 0-100
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student      @relation(fields: [studentId], references: [id])
  passage Passage      @relation(fields: [passageId], references: [id])
  season  StudySeason? @relation(fields: [seasonId], references: [id])

  @@unique([studentId, passageId, seasonId])
  @@index([studentId])
  @@map("lesson_progress")
}

/// SessionRecord — 세션 완료 기록
/// sessionType: "MIX_1" | "MIX_2" | "STORIES" | "VOCAB_FOCUS" | "GRAMMAR_FOCUS" | "WEAKNESS_FOCUS"
model SessionRecord {
  id               String   @id @default(cuid())
  studentId        String
  passageId        String
  seasonId         String?
  sessionType      String // "MIX_1" | "MIX_2" | "STORIES" | "VOCAB_FOCUS" | "GRAMMAR_FOCUS" | "WEAKNESS_FOCUS"
  score            Float // 정답률 0-100
  correctCount     Int
  totalCount       Int
  wrongQuestionIds String?  @db.Text // JSON: ["questionId1", ...]
  xpEarned         Int      @default(0)
  startedAt        DateTime @default(now())
  completedAt      DateTime @default(now())

  student Student      @relation(fields: [studentId], references: [id])
  passage Passage      @relation(fields: [passageId], references: [id])
  season  StudySeason? @relation(fields: [seasonId], references: [id])

  @@index([studentId])
  @@index([studentId, completedAt]) // 주간 XP 랭킹 계산용
  @@index([passageId])
  @@map("session_records")
}

/// StudentDailyMission — 데일리 미션 추적
model StudentDailyMission {
  id                  String    @id @default(cuid())
  studentId           String
  date                DateTime // 날짜 (시간 제외)
  easyCompleted       Boolean   @default(false)
  hardCompleted       Boolean   @default(false)
  multiplierActive    Float? // 1.2 or 2.0
  multiplierExpiresAt DateTime?
  createdAt           DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@index([studentId])
  @@map("student_daily_missions")
}

// ============================================================================
// 17. 수능링고 — 글로벌 학습 시스템 (academyId 없음)
// ============================================================================

/// SuneungPassage — 수능/모의고사 공용 지문 (플랫폼 전체 공유)
model SuneungPassage {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  source     String? // "2025 수능", "2024 9월 모의고사" 등
  grade      Int // 7~12
  year       Int? // 출제 연도
  examType   String? // "SUNEUNG" | "MOCK_6" | "MOCK_9" | "EBS" | "OTHER"
  difficulty String? // "BEGINNER" ~ "EXPERT"
  tags       String?  @db.Text
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  analysis  SuneungPassageAnalysis?
  questions SuneungQuestion[]

  @@index([grade])
  @@map("suneung_passages")
}

/// SuneungPassageAnalysis — 수능 지문 AI 분석 캐시
model SuneungPassageAnalysis {
  id           String   @id @default(cuid())
  passageId    String   @unique
  analysisData String   @db.Text // JSON: 5레이어 분석 구조
  contentHash  String
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passage SuneungPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@map("suneung_passage_analyses")
}

// ============================================================================
// 18. 내신링고 — 학원별 학습 문제 시스템
// ============================================================================

/// LearningSet — 학습 문제 세트 (출판사/교재/단원 기준 그룹핑)
model LearningSet {
  id            String   @id @default(cuid())
  academyId     String
  passageId     String // 원본 지문 참조 (분석 데이터 활용)
  publisher     String // 출판사 (능률(양), 비상(홍) 등)
  textbook      String? // 교재명
  grade         Int? // 학년
  unit          String? // 단원/과
  title         String // 세트 제목
  questionCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  academy   Academy           @relation(fields: [academyId], references: [id])
  passage   Passage           @relation(fields: [passageId], references: [id])
  questions NaeshinQuestion[]

  @@index([academyId])
  @@index([academyId, publisher])
  @@map("learning_sets")
}

/// NaeshinQuestion — 내신링고 학습 전용 문제
model NaeshinQuestion {
  id               String   @id @default(cuid())
  academyId        String
  passageId        String
  learningSetId    String? // 학습 세트 소속
  learningCategory String // "VOCAB" | "INTERPRETATION" | "GRAMMAR" | "COMPREHENSION"
  type             String // interaction type
  subType          String? // 23종 subType
  questionText     String   @db.Text
  options          String?  @db.Text // JSON: [{ label, text }]
  correctAnswer    String   @db.Text
  difficulty       String   @default("INTERMEDIATE")
  tags             String?  @db.Text // JSON array
  aiGenerated      Boolean  @default(true)
  approved         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academy     Academy                     @relation(fields: [academyId], references: [id])
  passage     Passage                     @relation(fields: [passageId], references: [id])
  learningSet LearningSet?                @relation(fields: [learningSetId], references: [id])
  school      School?                     @relation(fields: [schoolId], references: [id])
  schoolId    String?
  explanation NaeshinQuestionExplanation?
  wrongLogs   NaeshinWrongAnswerLog[]

  @@index([passageId, learningCategory])
  @@index([academyId])
  @@index([learningSetId])
  @@map("naeshin_questions")
}

/// NaeshinQuestionExplanation — 내신 학습 문제 해설
model NaeshinQuestionExplanation {
  id                      String   @id @default(cuid())
  questionId              String   @unique
  content                 String   @db.Text
  keyPoints               String?  @db.Text
  wrongOptionExplanations String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  question NaeshinQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("naeshin_question_explanations")
}

/// NaeshinWrongAnswerLog — 내신링고 오답 기록
model NaeshinWrongAnswerLog {
  id          String   @id @default(cuid())
  studentId   String
  questionId  String
  givenAnswer String
  category    String?
  subCategory String?
  count       Int      @default(1)
  lastWrongAt DateTime @default(now())

  student  Student         @relation(fields: [studentId], references: [id])
  question NaeshinQuestion @relation(fields: [questionId], references: [id])

  @@unique([studentId, questionId])
  @@index([studentId, category])
  @@map("naeshin_wrong_answer_logs")
}

// ============================================================================
// 19. 수능링고 — 글로벌 학습 문제
// ============================================================================

/// SuneungQuestion — 수능링고 학습 전용 문제 (academyId 없음)
model SuneungQuestion {
  id               String   @id @default(cuid())
  passageId        String
  learningCategory String // "VOCAB" | "INTERPRETATION" | "GRAMMAR" | "COMPREHENSION"
  type             String // "MULTIPLE_CHOICE" | "SHORT_ANSWER"
  subType          String?
  questionText     String   @db.Text
  options          String?  @db.Text
  correctAnswer    String   @db.Text
  difficulty       String   @default("INTERMEDIATE")
  grade            Int // 대상 학년
  tags             String?  @db.Text
  aiGenerated      Boolean  @default(true)
  approved         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  passage     SuneungPassage              @relation(fields: [passageId], references: [id])
  explanation SuneungQuestionExplanation?
  wrongLogs   SuneungWrongAnswerLog[]

  @@index([passageId, learningCategory])
  @@index([grade])
  @@map("suneung_questions")
}

/// SuneungQuestionExplanation — 수능 학습 문제 해설
model SuneungQuestionExplanation {
  id                      String   @id @default(cuid())
  questionId              String   @unique
  content                 String   @db.Text
  keyPoints               String?  @db.Text
  wrongOptionExplanations String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  question SuneungQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("suneung_question_explanations")
}

/// SuneungWrongAnswerLog — 수능링고 오답 기록
model SuneungWrongAnswerLog {
  id          String   @id @default(cuid())
  studentId   String
  questionId  String
  givenAnswer String
  category    String?
  subCategory String?
  count       Int      @default(1)
  lastWrongAt DateTime @default(now())

  student  Student         @relation(fields: [studentId], references: [id])
  question SuneungQuestion @relation(fields: [questionId], references: [id])

  @@unique([studentId, questionId])
  @@index([studentId, category])
  @@map("suneung_wrong_answer_logs")
}

// ============================================================================
// PASSAGE COLLECTIONS — Folder-like organization for passages
// ============================================================================

model PassageCollection {
  id          String   @id @default(cuid())
  academyId   String
  parentId    String? // Self-reference for nested folders (null = root)
  name        String
  description String?  @db.Text
  color       String? // Hex color for visual distinction
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy  Academy                 @relation(fields: [academyId], references: [id])
  parent   PassageCollection?      @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children PassageCollection[]     @relation("FolderTree")
  items    PassageCollectionItem[]

  @@index([academyId])
  @@index([parentId])
  @@map("passage_collections")
}

model PassageCollectionItem {
  id           String @id @default(cuid())
  collectionId String
  passageId    String
  orderNum     Int    @default(0)

  collection PassageCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  passage    Passage           @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@unique([collectionId, passageId])
  @@index([collectionId])
  @@map("passage_collection_items")
}

// ============================================================================
// EXAM COLLECTIONS — Folder-like organization for exams
// ============================================================================

model ExamCollection {
  id          String   @id @default(cuid())
  academyId   String
  parentId    String? // Self-reference for nested folders (null = root)
  name        String
  description String?  @db.Text
  color       String? // Hex color for visual distinction
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy  Academy              @relation(fields: [academyId], references: [id])
  parent   ExamCollection?      @relation("ExamFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ExamCollection[]     @relation("ExamFolderTree")
  items    ExamCollectionItem[]

  @@index([academyId])
  @@index([parentId])
  @@map("exam_collections")
}

model ExamCollectionItem {
  id           String @id @default(cuid())
  collectionId String
  examId       String
  orderNum     Int    @default(0)

  collection ExamCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  exam       Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([collectionId, examId])
  @@index([collectionId])
  @@map("exam_collection_items")
}

// ============================================================================
// 20. PLATFORM ADMINISTRATION
// ============================================================================

/// SuperAdmin — Platform-level administrator (developer/operator)
/// role: "SUPER_ADMIN" | "SUPPORT"
model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("SUPER_ADMIN") // "SUPER_ADMIN" | "SUPPORT"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewedRegistrations AcademyRegistration[] @relation("ReviewedBy")
  creditAdjustments     CreditTransaction[]   @relation("AdjustedBy")

  @@map("super_admins")
}

// ============================================================================
// 21. SUBSCRIPTION & BILLING
// ============================================================================

/// SubscriptionPlan — Catalog of available plans
/// tier: "STARTER" | "STANDARD" | "PREMIUM" | "ENTERPRISE"
/// rolloverPolicy: "RESET" | "ROLLOVER" | "PARTIAL_ROLLOVER"
model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String // "스타터", "스탠다드", "프리미엄", "엔터프라이즈"
  tier            String   @unique // "STARTER" | "STANDARD" | "PREMIUM" | "ENTERPRISE"
  monthlyPrice    Int // KRW (300000, 500000, 1000000, 0)
  monthlyCredits  Int // 500, 1200, 3000, custom
  maxStudents     Int // 50, 150, 500, 99999
  maxStaff        Int // 3, 8, 20, 99999
  features        String   @db.Text // JSON: feature flags object
  rolloverPolicy  String   @default("RESET") // "RESET" | "ROLLOVER" | "PARTIAL_ROLLOVER"
  rolloverMaxRate Float    @default(0) // For PARTIAL_ROLLOVER: 0.2 = carry over up to 20%
  description     String?  @db.Text
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions AcademySubscription[]

  @@map("subscription_plans")
}

/// AcademySubscription — Active subscription per academy
/// status: "TRIAL" | "ACTIVE" | "PAST_DUE" | "CANCELLED" | "SUSPENDED"
model AcademySubscription {
  id                 String    @id @default(cuid())
  academyId          String
  planId             String
  status             String    @default("TRIAL") // "TRIAL" | "ACTIVE" | "PAST_DUE" | "CANCELLED" | "SUSPENDED"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  graceEndsAt        DateTime? // Read-only access after expiry, before suspension
  paymentMethod      String? // "CARD" | "TRANSFER" | "KAKAO_PAY"
  paymentReference   String? // External payment system reference
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  academy Academy          @relation(fields: [academyId], references: [id])
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([academyId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("academy_subscriptions")
}

// ============================================================================
// 22. CREDIT SYSTEM
// ============================================================================

/// CreditBalance — Current credit state per academy (one row per academy)
model CreditBalance {
  id                 String    @id @default(cuid())
  academyId          String    @unique
  balance            Int       @default(0) // Current available credits
  monthlyAllocation  Int       @default(0) // Credits from subscription plan
  bonusCredits       Int       @default(0) // Remaining top-up credits
  totalConsumed      Int       @default(0) // Lifetime consumption
  totalAllocated     Int       @default(0) // Lifetime allocation
  lowCreditThreshold Int       @default(50) // Warning threshold
  lastResetAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  academy Academy @relation(fields: [academyId], references: [id])

  @@map("credit_balances")
}

/// CreditTransaction — Immutable audit log of every credit movement
/// type: "ALLOCATION" | "CONSUMPTION" | "TOP_UP" | "ADJUSTMENT" | "REFUND" | "RESET" | "ROLLOVER"
model CreditTransaction {
  id            String   @id @default(cuid())
  academyId     String
  type          String // "ALLOCATION" | "CONSUMPTION" | "TOP_UP" | "ADJUSTMENT" | "REFUND" | "RESET" | "ROLLOVER"
  amount        Int // Positive = add, Negative = consume
  balanceAfter  Int // Snapshot of balance after this transaction
  operationType String? // "QUESTION_GEN_SINGLE" | "PASSAGE_ANALYSIS" | etc
  description   String?
  referenceId   String? // Related entity ID (questionId, passageId, etc.)
  referenceType String? // "QUESTION" | "PASSAGE" | "EXAM" | "CREDIT_TRANSACTION"
  staffId       String? // Staff member who triggered the operation
  adminId       String? // SuperAdmin who made manual adjustment
  metadata      String?  @db.Text // JSON: { model, inputTokens, outputTokens, costUsd, durationMs, promptHash }
  createdAt     DateTime @default(now())

  academy Academy     @relation(fields: [academyId], references: [id])
  admin   SuperAdmin? @relation("AdjustedBy", fields: [adminId], references: [id])

  @@index([academyId, createdAt])
  @@index([academyId, type])
  @@index([academyId, operationType])
  @@index([staffId])
  @@index([createdAt])
  @@map("credit_transactions")
}

/// CreditTopUp — Additional credit purchase records
/// status: "PENDING" | "COMPLETED" | "FAILED" | "REFUNDED"
model CreditTopUp {
  id               String    @id @default(cuid())
  academyId        String
  creditAmount     Int // Credits purchased
  price            Int // KRW paid
  paymentMethod    String? // "CARD" | "TRANSFER" | "KAKAO_PAY"
  paymentReference String? // External transaction ID
  status           String    @default("PENDING") // "PENDING" | "COMPLETED" | "FAILED" | "REFUNDED"
  completedAt      DateTime?
  requestedBy      String? // staffId
  createdAt        DateTime  @default(now())

  academy Academy @relation(fields: [academyId], references: [id])

  @@index([academyId])
  @@index([status])
  @@map("credit_top_ups")
}

// ============================================================================
// 23. ACADEMY REGISTRATION
// ============================================================================

/// AcademyRegistration — Pending registration requests from new academies
/// status: "PENDING" | "APPROVED" | "REJECTED" | "CANCELLED"
model AcademyRegistration {
  id                String    @id @default(cuid())
  // Academy info
  academyName       String
  businessNumber    String? // 사업자등록번호
  phone             String
  address           String?
  district          String? // Extracted Seoul district (e.g. "강남구") for campaign tracking
  estimatedStudents Int?
  // Director info
  directorName      String
  directorEmail     String
  directorPhone     String
  // Request
  message           String?   @db.Text
  desiredPlan       String? // Requested tier
  // Review
  status            String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED" | "CANCELLED"
  reviewedById      String?
  reviewNote        String?   @db.Text
  reviewedAt        DateTime?
  // Result (set on approval)
  academyId         String? // Created Academy ID
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reviewedBy SuperAdmin? @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([district])
  @@index([desiredPlan])
  @@map("academy_registrations")
}

// ============================================================================
// 24. BULK PASSAGE EXTRACTION — PDF/image → passages pipeline
// ============================================================================

/// ExtractionJob — 하나의 "대량 추출" 요청 단위
/// status: "PENDING" | "PROCESSING" | "COMPLETED" | "PARTIAL" | "FAILED" | "CANCELLED"
/// sourceType: "PDF" | "IMAGES"
/// mode: "PASSAGE_ONLY" | "QUESTION_SET" | "EXPLANATION" | "FULL_EXAM"
///   - PASSAGE_ONLY (M1): 본문만 뽑아 지문 라이브러리에 적재
///   - QUESTION_SET  (M2): 지문+문제+선지(+정답) → 문제 은행
///   - EXPLANATION   (M3): 해설지 → 기존 Question에 매핑
///   - FULL_EXAM     (M4): 지문+문제+시험지(Exam) 통째
model ExtractionJob {
  id          String @id @default(cuid())
  academyId   String
  createdById String // staff.id

  sourceType       String // "PDF" | "IMAGES"
  mode             String  @default("PASSAGE_ONLY") // M1 ~ M4 (see header)
  originalFileUrl  String? @db.Text // Supabase Storage path for source PDF
  originalFileName String?

  // Upstream "a single exam / worksheet" it materialises into.
  // Populated by extraction-finalize when the job reaches a terminal state.
  sourceMaterialId String?

  status       String @default("PENDING")
  totalPages   Int
  successPages Int    @default(0)
  failedPages  Int    @default(0)
  pendingPages Int // init = totalPages

  creditsReserved Int @default(0) // pre-flight projected cost (not actually charged)
  creditsConsumed Int @default(0) // sum of successful page charges
  creditsRefunded Int @default(0) // sum of refunds

  concurrencyLimit Int     @default(5)
  triggerRunId     String? @db.Text // Trigger.dev orchestrator run handle (cancel/cleanup)

  errorSummary String? @db.Text // JSON summary of errors

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  academy        Academy            @relation(fields: [academyId], references: [id])
  createdBy      Staff              @relation("ExtractionJobCreator", fields: [createdById], references: [id])
  sourceMaterial SourceMaterial?    @relation(fields: [sourceMaterialId], references: [id])
  pages          ExtractionPage[]
  results        ExtractionResult[]
  items          ExtractionItem[]

  @@index([academyId, status])
  @@index([academyId, createdAt])
  @@index([status, createdAt])
  @@index([sourceMaterialId])
  @@map("extraction_jobs")
}

/// ExtractionPage — 페이지 1장 = Gemini 호출 1회 단위 (원자 단위)
/// status: "PENDING" | "PROCESSING" | "SUCCESS" | "FAILED" | "DEAD" | "SKIPPED"
/// idempotencyKey = `${jobId}:${pageIndex}` — UNIQUE로 3중 방어선의 2차 방벽 역할
model ExtractionPage {
  id         String @id @default(cuid())
  jobId      String
  pageIndex  Int // 0-based 순서
  imageUrl   String @db.Text // Supabase Storage key (not public URL)
  imageBytes Int?

  status       String @default("PENDING")
  attemptCount Int    @default(0)
  maxAttempts  Int    @default(3)

  // ─── 멱등성 핵심 ──────────────────────────────
  idempotencyKey String // `${jobId}:${pageIndex}` — UNIQUE
  leaseOwner     String? // Trigger.dev run id
  leaseExpiresAt DateTime? // stuck lease 복구용

  // ─── 결과 ─────────────────────────────────────
  extractedText String? @db.Text
  confidence    Float?
  modelUsed     String?
  inputTokens   Int?
  outputTokens  Int?
  latencyMs     Int?

  // ─── 크레딧 연결 ──────────────────────────────
  creditTxId String? // CreditTransaction.id for dedup on retry

  // ─── 에러 ─────────────────────────────────────
  errorCode    String?
  errorMessage String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  job   ExtractionJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  items ExtractionItem[]

  @@unique([idempotencyKey])
  @@unique([jobId, pageIndex])
  @@index([jobId, status])
  @@index([status, leaseExpiresAt])
  @@map("extraction_pages")
}

/// ExtractionResult — 지문 단위 결과 (세그멘테이션 후 산출물)
/// status: "DRAFT" | "REVIEWED" | "SAVED" | "SKIPPED"
model ExtractionResult {
  id           String @id @default(cuid())
  jobId        String
  passageOrder Int // job 내 정렬

  sourcePageIndex Int[] // 예: [3,4,5] — 여러 페이지 걸친 지문 지원

  title   String?
  content String  @db.Text
  meta    Json? // { markerDetected, mergedFromPages, confidenceNote }

  confidence     Float?
  status         String  @default("DRAFT")
  savedPassageId String? // Passage.id after commit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job ExtractionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, passageOrder])
  @@index([jobId, status])
  @@map("extraction_results")
}

// ============================================================================
// 25. EXTRACTION ITEMS — granular block-level representation
// ============================================================================
// Replaces the legacy ExtractionResult for new jobs. Each extracted document
// is represented as a tree of typed blocks (passage body, question stem,
// choice, explanation, exam meta, etc.) with parent/child relationships so
// the review UI can classify, regroup, and promote them into proper Passage /
// Question / QuestionExplanation / SourceMaterial records.
// ============================================================================

/// ExtractionItem — a typed block emitted by segmentation
/// blockType: "PASSAGE_BODY" | "QUESTION_STEM" | "CHOICE" | "EXPLANATION" | "EXAM_META" | "HEADER" | "FOOTER" | "DIAGRAM" | "NOISE"
/// status:    "DRAFT" | "REVIEWED" | "PROMOTED" | "SKIPPED" | "MERGED"
model ExtractionItem {
  id              String  @id @default(cuid())
  jobId           String
  pageId          String? // ExtractionPage.id (null when item spans multiple pages)
  sourcePageIndex Int[] // supports multi-page items

  // ─── Identity ────────────────────────────────
  blockType    String
  groupId      String? // passage↔question↔choice clustering key (job-scoped)
  parentItemId String? // CHOICE → QUESTION_STEM / EXPLANATION → QUESTION_STEM

  order      Int // global order within job
  localOrder Int? // position within parent group (1st choice, 2nd choice, ...)

  // ─── Content ─────────────────────────────────
  title   String?
  content String  @db.Text // editable final text (what review UI shows)
  rawText String? @db.Text // original OCR text — preserved verbatim

  // ─── Type-specific metadata (Json, validated per blockType in app layer) ──
  questionMeta Json? // { number, points, pattern, answerChoice, ... }
  choiceMeta   Json? // { index, label, isAnswer }
  passageMeta  Json? // { wordCount, paragraphCount, markerDetected }
  examMeta     Json? // { subject, grade, year, round, publisher, school }

  boundingBox Json? // { page, x, y, w, h } — click-to-highlight in viewer

  // ─── Quality ────────────────────────────────
  confidence  Float?
  needsReview Boolean @default(false)
  status      String  @default("DRAFT")

  // ─── Promotion tracking ─────────────────────
  // URN string — e.g. "Passage:clxxxxx" / "Question:clxxxxx" / "QuestionExplanation:clxxxxx"
  promotedTo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job      ExtractionJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  page     ExtractionPage?  @relation(fields: [pageId], references: [id], onDelete: SetNull)
  parent   ExtractionItem?  @relation("ItemTree", fields: [parentItemId], references: [id], onDelete: SetNull)
  children ExtractionItem[] @relation("ItemTree")

  @@index([jobId, order])
  @@index([jobId, blockType])
  @@index([jobId, groupId])
  @@index([parentItemId])
  @@map("extraction_items")
}

// ============================================================================
// 26. SOURCE MATERIAL — "a single exam / textbook / worksheet" as first-class citizen
// ============================================================================
// Every Passage / Question / Exam that originated from a physical document
// points back to one SourceMaterial. This is the hub that lets us answer
// "where did this passage come from?" and "show me everything from that exam"
// without denormalising metadata into every child row.
// ============================================================================

/// SourceMaterial — one physical source document (exam paper, textbook chapter, handout)
/// type: "EXAM" | "TEXTBOOK" | "WORKBOOK" | "HANDOUT" | "MOCK" | "SUNEUNG" | "OTHER"
/// subject: "ENGLISH" | "KOREAN" | "MATH" | "OTHER"
/// examType: "MIDTERM" | "FINAL" | "MOCK" | "SUNEUNG" | "DIAGNOSTIC" | "EBS" | "PRIVATE"
model SourceMaterial {
  id        String  @id @default(cuid())
  academyId String
  schoolId  String?

  type     String
  title    String
  subtitle String?

  // Common metadata (first-class columns for fast filtering)
  subject   String? @default("ENGLISH")
  grade     Int?
  semester  String? // "FIRST" | "SECOND"
  year      Int?
  round     String? // "6월", "9월", "11월" or "1회", "2회"
  examType  String?
  publisher String?
  sourceRef String? // free-form reference (URL, ISBN, distributor)

  // Extraction linkage
  originalFileUrl String? @db.Text // archived PDF in Supabase Storage
  contentHash     String? // sha1 of concatenated extracted texts — duplicate detection

  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy   Academy @relation(fields: [academyId], references: [id])
  school    School? @relation(fields: [schoolId], references: [id])
  createdBy Staff?  @relation("SourceMaterialCreator", fields: [createdById], references: [id])

  bundles        PassageBundle[]
  passages       Passage[]
  questions      Question[]
  exams          Exam[]
  extractionJobs ExtractionJob[]

  @@unique([academyId, contentHash], name: "academy_content_hash_unique")
  @@index([academyId, type])
  @@index([academyId, grade, year])
  @@index([academyId, createdAt])
  @@index([schoolId])
  @@index([contentHash])
  @@map("source_materials")
}

// ============================================================================
// 27. PASSAGE BUNDLE — a passage + its shared questions (e.g. CSAT [2~4])
// ============================================================================

/// PassageBundle — groups one passage with its sharing questions, scoped per source
/// A single Passage can appear in multiple bundles (reused across exams).
model PassageBundle {
  id               String  @id @default(cuid())
  sourceMaterialId String
  passageId        String
  orderInMaterial  Int // order within the source (e.g. passage #2 on the exam)
  sharedLabel      String? // "[32~34]" label as printed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceMaterial SourceMaterial @relation(fields: [sourceMaterialId], references: [id], onDelete: Cascade)
  passage        Passage        @relation(fields: [passageId], references: [id], onDelete: Cascade)
  questions      Question[]     @relation("BundleQuestions")

  @@unique([sourceMaterialId, passageId])
  @@index([sourceMaterialId])
  @@index([passageId])
  @@map("passage_bundles")
}
